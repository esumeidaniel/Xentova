PORT=4000
HOST=127.0.0.1
NODE_ENV=development
FRONTEND_URL=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local demo mode works without Supabase. Disable before production.
DEMO_AUTH_ENABLED=true

# Public market data. Set MARKET_DATA_PROVIDER=bybit to switch provider.
LIVE_MARKET_DATA=true
MARKET_DATA_PROVIDER=binance
BINANCE_REST_URL=https://api.binance.com
BYBIT_REST_URL=https://api.bybit.com
